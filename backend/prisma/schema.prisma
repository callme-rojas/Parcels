generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id            String        @id @default(uuid()) @db.Uuid
  nombre        String
  email         String        @unique
  passwordHash  String
  rol           Rol           @default(CLIENTE)
  activo        Boolean       @default(true)
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt
  telefono      String?
  eventos       ParcelEvent[]

  @@map("usuarios")
}

model Parcel {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trackingNumber     String                @unique
  senderName         String
  senderCi           String
  senderPhone        String
  senderEmail        String
  recipientName      String
  recipientCi        String
  recipientPhone     String
  recipientEmail     String?
  content            String
  weight             Float
  observations       String?
  routeCode          String
  originAddress      String
  destinationAddress String
  originLat          Float
  originLng          Float
  destinationLat     Float
  destinationLng     Float
  status             ParcelStatus          @default(REGISTRADO)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @default(now()) @updatedAt
  deliveredAt        DateTime?
  assignedBusPlaca   String?
  assignedBusFlota   String?
  assignedBusId      String?               @db.Uuid
  altoCm             Float?
  anchoCm            Float?
  categoria          CategoriaContenido?
  costoEnvio         Float?
  esFragil           Boolean               @default(false)
  estadoPago         EstadoPago            @default(PENDIENTE)
  largoCm            Float?
  pagadoEn           DateTime?
  tipoPago           TipoPago              @default(REMITENTE)
  busAssignments     ParcelBusAssignment[]
  events             ParcelEvent[]
  assignedBus        Bus?                  @relation(fields: [assignedBusId], references: [id])

  @@map("parcels")
}

model Bus {
  id               String                @id @default(uuid()) @db.Uuid
  placa            String                @unique
  modelo           String?
  flota            String
  routeCode        String
  routeLabel       String
  capacidad        Int                   @default(30)
  estado           BusEstado             @default(CARGANDO)
  activo           Boolean               @default(true)
  salidaProgramada String?
  conductor        String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  trackingEvents   BusTrackingEvent[]
  assignments      ParcelBusAssignment[]
  parcels          Parcel[]

  @@map("buses")
}

model ParcelBusAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  parcelId   String    @db.Uuid
  busId      String    @db.Uuid
  assignedAt DateTime  @default(now())
  loadedAt   DateTime?
  unloadedAt DateTime?
  isActive   Boolean   @default(true)
  bus        Bus       @relation(fields: [busId], references: [id], onDelete: Cascade)
  parcel     Parcel    @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@index([parcelId, isActive])
  @@map("parcel_bus_assignments")
}

model BusTrackingEvent {
  id         String   @id @default(uuid()) @db.Uuid
  busId      String   @db.Uuid
  lat        Float
  lng        Float
  velocidad  Float?
  recordedAt DateTime @default(now())
  bus        Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@index([busId, recordedAt])
  @@map("bus_tracking_events")
}

model ParcelEvent {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parcelId  String       @db.Uuid
  status    ParcelStatus
  note      String?
  usuarioId String?      @db.Uuid
  createdAt DateTime     @default(now())
  parcel    Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  usuario   Usuario?     @relation(fields: [usuarioId], references: [id])

  @@index([parcelId])
  @@index([usuarioId])
  @@map("parcel_events")
}

model Sucursal {
  id            String   @id @default(uuid()) @db.Uuid
  nombre        String
  ciudad        String
  direccion     String
  telefono      String?
  activa        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("sucursales")
}

enum Rol {
  ADMINISTRADOR
  TAQUILLA
  BODEGA
  CLIENTE
}

enum ParcelStatus {
  REGISTRADO
  RECEPCIONADO
  EN_TRANSITO
  EN_DESTINO
  DISPONIBLE
  ENTREGADO
  CANCELADO
}

enum BusEstado {
  CARGANDO
  LISTO
  EN_RUTA
  INACTIVO
}

enum CategoriaContenido {
  DOCUMENTOS
  ROPA
  ELECTRONICO
  ALIMENTOS
  HERRAMIENTAS
  MEDICAMENTOS
  OTRO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  EXONERADO
}

enum TipoPago {
  REMITENTE
  DESTINATARIO
}
